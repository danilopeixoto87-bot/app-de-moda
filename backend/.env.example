# --- Backend obrigatorio ---
APP_SECRET_KEY=gere_com_openssl_rand_-hex_32
ALLOWED_ORIGINS=https://seu-app.vercel.app,http://localhost:3000

# --- PostgreSQL (Supabase Session Pooler) ---
DATABASE_URL=postgresql://postgres.SEU_REF:SUA_SENHA@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# --- Supabase Storage ---
SUPABASE_URL=https://SEU_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=product-images

# --- Replicate (geracao de imagens IA) ---
REPLICATE_API_TOKEN=r8_...

# --- Mercado Pago ---
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_URL=https://seu-backend.railway.app/api/portal/webhook/mercadopago
MP_WEBHOOK_SECRET=gere_um_secret_aleatorio

# URLs de retorno do checkout
MP_SUCCESS_URL=https://seu-app.vercel.app/checkout/sucesso
MP_PENDING_URL=https://seu-app.vercel.app/checkout/pendente
MP_FAILURE_URL=https://seu-app.vercel.app/checkout/falha

# --- Comportamento ---
SEED_ON_STARTUP=false
DEBUG=false
